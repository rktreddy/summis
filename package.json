{
  "name": "thousandx",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "demo": "EXPO_PUBLIC_DEMO_MODE=true expo start",
    "demo:free": "EXPO_PUBLIC_DEMO_MODE=true EXPO_PUBLIC_DEMO_TIER=free expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:ios": "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "test": "jest",
    "db:push": "supabase db push",
    "deploy:functions": "supabase functions deploy"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "dependencies": {
    "@expo/cli": "^55.0.18",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/native": "^7.1.33",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.99.2",
    "expo": "~55.0.8",
    "expo-apple-authentication": "^55.0.9",
    "expo-constants": "~55.0.9",
    "expo-device": "^55.0.10",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.8",
    "expo-notifications": "^55.0.13",
    "expo-router": "~55.0.7",
    "expo-secure-store": "^55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.10",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.83.2",
    "react-native-purchases": "^9.14.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^3.3.2",
    "victory-native": "^41.20.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "eas-cli": "^18.4.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
